{
  "manifest_version": 3,
  "name": "3tz",
  "version": "1.0.0",
  "description": "Check a US area code's timezone.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Area Code Timezone Checker"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Open the area code popup"
    }
  }
}
